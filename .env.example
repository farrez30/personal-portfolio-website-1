# Copy to .env.local and fill in real values. All are optional — the contact
# form falls back to the values baked into components/contact/Contact.jsx.

# EmailJS (https://dashboard.emailjs.com) — used by "Send via Email".
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# WhatsApp number (country code, digits only, no + or spaces) — used by
# "Send via WhatsApp". Example: 6285884061543
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Canonical site URL for SEO metadata (defaults to https://farrez.vercel.app).
NEXT_PUBLIC_SITE_URL=
